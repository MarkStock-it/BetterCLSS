CANVAS_DOMAIN=usc.instructure.com
# Optional fallback token for admin/single-user mode only.
CANVAS_TOKEN=

# Optional frontend override if static site points to separate backend.
# Browser users can also set this in the Connect Canvas modal.
# BCLSS_API_BASE_URL=https://your-backend.example.com

PORT=5500
MAX_OVERDUE_DAYS=30

# AI assistant (OpenClaude-compatible / OpenAI-compatible endpoint)
OPENCLAUDE_BASE_URL=http://127.0.0.1:1337/v1
OPENCLAUDE_MODEL=qwen2.5-coder:7b
OPENCLAUDE_API_KEY=

# Auto-start local Ollama when first AI prompt arrives (0/1)
AI_AUTOSTART_OLLAMA=1

# Unload model immediately after each response to save resources
AI_MODEL_KEEP_ALIVE=0m

# CORS for static frontend -> backend API requests
# Use * or set your GitHub Pages origin, e.g. https://markstock-it.github.io
CORS_ALLOW_ORIGIN=*
